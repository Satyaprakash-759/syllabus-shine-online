{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/p/[slug]",
      "regex": "^/p/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/p/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/cambridge",
      "regex": "^/cambridge(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/cambridge(?:/)?$"
    },
    {
      "page": "/cambridge/a-level",
      "regex": "^/cambridge/a\\-level(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/cambridge/a\\-level(?:/)?$"
    },
    {
      "page": "/cambridge/as-level",
      "regex": "^/cambridge/as\\-level(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/cambridge/as\\-level(?:/)?$"
    },
    {
      "page": "/cambridge/igcse",
      "regex": "^/cambridge/igcse(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/cambridge/igcse(?:/)?$"
    },
    {
      "page": "/cambridge/o-level",
      "regex": "^/cambridge/o\\-level(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/cambridge/o\\-level(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/faq",
      "regex": "^/faq(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/faq(?:/)?$"
    },
    {
      "page": "/ib",
      "regex": "^/ib(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/ib(?:/)?$"
    },
    {
      "page": "/ib/diploma",
      "regex": "^/ib/diploma(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/ib/diploma(?:/)?$"
    },
    {
      "page": "/ib/middle-years",
      "regex": "^/ib/middle\\-years(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/ib/middle\\-years(?:/)?$"
    },
    {
      "page": "/ib/primary-years",
      "regex": "^/ib/primary\\-years(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/ib/primary\\-years(?:/)?$"
    },
    {
      "page": "/international",
      "regex": "^/international(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/international(?:/)?$"
    },
    {
      "page": "/international/canadian",
      "regex": "^/international/canadian(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/international/canadian(?:/)?$"
    },
    {
      "page": "/international/indian",
      "regex": "^/international/indian(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/international/indian(?:/)?$"
    },
    {
      "page": "/international/singaporean",
      "regex": "^/international/singaporean(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/international/singaporean(?:/)?$"
    },
    {
      "page": "/privacy-policy",
      "regex": "^/privacy\\-policy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/privacy\\-policy(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}